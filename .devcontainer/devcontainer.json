{
  "name": "Windows Cloud OS (Stable)",

  "image": "mcr.microsoft.com/devcontainers/base:debian",

  "remoteUser": "vscode",

  "forwardPorts": [6080],

  "portsAttributes": {
    "6080": {
      "label": "Desktop (noVNC)",
      "onAutoForward": "openBrowser"
    }
  },

  "postCreateCommand": "bash .devcontainer/install.sh",
  "postStartCommand": "bash .devcontainer/start.sh"
}